# Leave HF_API_TOKEN empty to run 100% locally and free (uses google/flan-t5-base).
# Set it (a free token from huggingface.co/settings/tokens) to use a
# hosted instruction-tuned model instead, for noticeably better answers.
HF_API_TOKEN=
GENERATION_MODEL=mistralai/Mistral-7B-Instruct-v0.3
LOCAL_GENERATION_MODEL=google/flan-t5-base

CHUNK_SIZE=800
CHUNK_OVERLAP=120
TOP_K=4
MIN_SCORE=0.15
