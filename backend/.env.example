# ── Generation ────────────────────────────────────────────────────────────
# Leave HF_API_TOKEN empty to run 100% locally and free (uses flan-t5-base).
# Set it to a free token from huggingface.co/settings/tokens to use a
# hosted model via the HF Inference router (router.huggingface.co).
#
# Model note: the legacy api-inference.huggingface.co endpoint was
# decommissioned in late 2025. The new path uses provider="hf-inference"
# automatically. HuggingFaceH4/zephyr-7b-beta has the best free-tier
# availability as of mid-2025; large models like Mistral-7B require a
# paid HF Pro subscription on the hf-inference tier.
HF_API_TOKEN=
GENERATION_MODEL=HuggingFaceH4/zephyr-7b-beta
LOCAL_GENERATION_MODEL=google/flan-t5-base

# ── Chunking ──────────────────────────────────────────────────────────────
CHUNK_SIZE=800
CHUNK_OVERLAP=120

# ── Retrieval ─────────────────────────────────────────────────────────────
TOP_K=4
MIN_SCORE=0.15

# ── Uploads ───────────────────────────────────────────────────────────────
MAX_UPLOAD_MB=50

# ── CORS ──────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Restrict this before deploying.
ALLOWED_ORIGINS=http://localhost:3000
